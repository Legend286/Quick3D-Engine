# Binary assets marked as binary.
*.mdl     binary
*.ktx2    binary
*.ktx     binary
*.basis   binary
*.audio   binary
*.bin     binary


# Source files: prefer LF for cross-platform consistency.
*.c       text eol=lf
*.h       text eol=lf
*.cpp     text eol=lf
*.hpp     text eol=lf
*.cs      text eol=lf
*.cmake   text eol=lf
*.sh      text eol=lf
*.metal   text eol=lf
*.hlsl    text eol=lf
*.glsl    text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.yaml    text eol=lf
*.toml    text eol=lf
*.gitignore  text eol=lf
.editorconfig text eol=lf

# Linguist overrides for binary-ish extensions to count as data, not code.
*.ktx2 linguist-generated=true
*.basis linguist-generated=true
*.audio linguist-generated=true
*.mdl   linguist-generated=true
