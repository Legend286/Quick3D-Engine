<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:Engine.Editor.Views"
        x:Class="Engine.Editor.Views.MaterialEditorWindow"
        Title="Material Editor" Width="1000" Height="600" Topmost="True"
        Background="#1e1e1e">

  <Window.Styles>
    <Style Selector="Expander">
      <Setter Property="Background" Value="#252526" />
      <Setter Property="BorderBrush" Value="#333333" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Margin" Value="0,0,0,10" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Expander /template/ ToggleButton">
      <Setter Property="Foreground" Value="#d4d4d4" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.PropertyLabel">
      <Setter Property="Foreground" Value="#cccccc" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Margin" Value="0,0,10,0" />
    </Style>
    <Style Selector="NumericUpDown">
      <Setter Property="Background" Value="#3c3c3c" />
      <Setter Property="Foreground" Value="#d4d4d4" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="ShowButtonSpinner" Value="True" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="Height" Value="24" />
      <Setter Property="Padding" Value="4,0" />
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="Background" Value="#3c3c3c" />
      <Setter Property="Foreground" Value="#d4d4d4" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
  </Window.Styles>

  <Grid ColumnDefinitions="*,350">
    <views:ViewportMetalLayerHost Name="PreviewHost" Grid.Column="0" />
    
    <Border Grid.Column="1" Background="#1e1e1e" BorderBrush="#333333" BorderThickness="1,0,0,0">
      <ScrollViewer>
        <StackPanel Margin="15" Spacing="10">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Material Layer Stack" FontSize="16" FontWeight="Bold" Foreground="#ffffff" VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="+ Add Layer" Command="{Binding AddLayerCommand}" Background="#007acc" Foreground="#ffffff" Padding="8,4" CornerRadius="4" />
          </Grid>

          <!-- Base Layer -->
          <Expander Header="Base Material (Base Layer)" IsExpanded="True">
            <StackPanel Margin="10" Spacing="8">
              
              <Grid ColumnDefinitions="120,*">
                <TextBlock Classes="PropertyLabel" Text="Base Color" Grid.Column="0" />
                <Grid ColumnDefinitions="*,5,*,5,*" Grid.Column="1">
                  <NumericUpDown Grid.Column="0" Minimum="0" Maximum="1" Increment="0.01" Value="{Binding BaseColorR}" FormatString="0.00" />
                  <NumericUpDown Grid.Column="2" Minimum="0" Maximum="1" Increment="0.01" Value="{Binding BaseColorG}" FormatString="0.00" />
                  <NumericUpDown Grid.Column="4" Minimum="0" Maximum="1" Increment="0.01" Value="{Binding BaseColorB}" FormatString="0.00" />
                </Grid>
              </Grid>

              <Grid ColumnDefinitions="120,*">
                <TextBlock Classes="PropertyLabel" Text="Metallic" Grid.Column="0" />
                <NumericUpDown Grid.Column="1" Minimum="0" Maximum="1" Increment="0.01" Value="{Binding Metallic}" FormatString="0.00" />
              </Grid>

              <Grid ColumnDefinitions="120,*">
                <TextBlock Classes="PropertyLabel" Text="Roughness" Grid.Column="0" />
                <NumericUpDown Grid.Column="1" Minimum="0" Maximum="1" Increment="0.01" Value="{Binding Roughness}" FormatString="0.00" />
              </Grid>

              <!-- Texture Slots -->
              <Grid ColumnDefinitions="120,*">
                <TextBlock Classes="PropertyLabel" Text="Albedo Map" Grid.Column="0" />
                <TextBox Grid.Column="1" Text="{Binding BaseAlbedoTexture}" Watermark="Drop texture here..." DragDrop.AllowDrop="True" Name="BaseAlbedoBox" />
              </Grid>

              <Grid ColumnDefinitions="120,*">
                <TextBlock Classes="PropertyLabel" Text="Normal Map" Grid.Column="0" />
                <TextBox Grid.Column="1" Text="{Binding BaseNormalTexture}" Watermark="Drop normal texture here..." DragDrop.AllowDrop="True" Name="BaseNormalBox" />
              </Grid>

              <Grid ColumnDefinitions="120,*">
                <TextBlock Classes="PropertyLabel" Text="RMA Map" Grid.Column="0" />
                <TextBox Grid.Column="1" Text="{Binding BaseRmaTexture}" Watermark="Drop RMA texture here..." DragDrop.AllowDrop="True" Name="BaseRmaBox" />
              </Grid>
              
            </StackPanel>
          </Expander>

          <!-- Layer Stack Items -->
          <ItemsControl ItemsSource="{Binding Layers}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Expander Header="{Binding Name}" IsExpanded="True" Margin="0,0,0,10">
                  <StackPanel Margin="10" Spacing="8">
                    
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                      <TextBox Grid.Column="0" Text="{Binding Name}" FontWeight="Bold" Height="24" Padding="4,2" />
                      <Button Grid.Column="1" Content="▲" Command="{Binding $parent[Window].DataContext.MoveLayerUpCommand}" CommandParameter="{Binding}" Margin="4,0,0,0" Padding="4,2" />
                      <Button Grid.Column="2" Content="▼" Command="{Binding $parent[Window].DataContext.MoveLayerDownCommand}" CommandParameter="{Binding}" Margin="2,0,0,0" Padding="4,2" />
                      <Button Grid.Column="3" Content="✕" Command="{Binding $parent[Window].DataContext.RemoveLayerCommand}" CommandParameter="{Binding}" Margin="2,0,0,0" Foreground="#ff5555" Padding="4,2" />
                    </Grid>

                    <Grid ColumnDefinitions="120,*">
                      <TextBlock Classes="PropertyLabel" Text="Mask Type" Grid.Column="0" />
                      <ComboBox Grid.Column="1" SelectedIndex="{Binding MaskType}">
                        <ComboBoxItem>None</ComboBoxItem>
                        <ComboBoxItem>3D Perlin Noise</ComboBoxItem>
                        <ComboBoxItem>Voronoi (Cellular) Noise</ComboBoxItem>
                        <ComboBoxItem>FBM (Fractal) Noise</ComboBoxItem>
                        <ComboBoxItem>Turbulence Noise</ComboBoxItem>
                        <ComboBoxItem>Cavity (Ray Occlusion + Curvature)</ComboBoxItem>
                        <ComboBoxItem>Height (World Y Gradient)</ComboBoxItem>
                        <ComboBoxItem>Texture Mask</ComboBoxItem>
                      </ComboBox>
                    </Grid>

                    <Grid ColumnDefinitions="120,*">
                      <TextBlock Classes="PropertyLabel" Text="Noise Scale" Grid.Column="0" />
                      <NumericUpDown Grid.Column="1" Minimum="0.1" Maximum="200" Increment="1.0" Value="{Binding NoiseScale}" FormatString="0.0" />
                    </Grid>

                    <Grid ColumnDefinitions="120,*">
                      <TextBlock Classes="PropertyLabel" Text="Noise Octaves" Grid.Column="0" />
                      <NumericUpDown Grid.Column="1" Minimum="1" Maximum="8" Increment="1" Value="{Binding NoiseDetail}" FormatString="0" />
                    </Grid>

                    <Grid ColumnDefinitions="120,*">
                      <TextBlock Classes="PropertyLabel" Text="Noise Threshold" Grid.Column="0" />
                      <NumericUpDown Grid.Column="1" Minimum="0" Maximum="1" Increment="0.05" Value="{Binding NoiseThreshold}" FormatString="0.00" />
                    </Grid>

                    <Grid ColumnDefinitions="120,*">
                      <TextBlock Classes="PropertyLabel" Text="Mask Texture" Grid.Column="0" />
                      <TextBox Grid.Column="1" Text="{Binding MaskTexture}" Watermark="Drop mask texture here..." DragDrop.AllowDrop="True" />
                    </Grid>


                    <Grid ColumnDefinitions="120,*">
                      <TextBlock Classes="PropertyLabel" Text="Layer Color" Grid.Column="0" />
                      <Grid ColumnDefinitions="*,5,*,5,*" Grid.Column="1">
                        <NumericUpDown Grid.Column="0" Minimum="0" Maximum="1" Increment="0.01" Value="{Binding ColorR}" FormatString="0.00" />
                        <NumericUpDown Grid.Column="2" Minimum="0" Maximum="1" Increment="0.01" Value="{Binding ColorG}" FormatString="0.00" />
                        <NumericUpDown Grid.Column="4" Minimum="0" Maximum="1" Increment="0.01" Value="{Binding ColorB}" FormatString="0.00" />
                      </Grid>
                    </Grid>

                    <Grid ColumnDefinitions="120,*">
                      <TextBlock Classes="PropertyLabel" Text="Metallic" Grid.Column="0" />
                      <NumericUpDown Grid.Column="1" Minimum="0" Maximum="1" Increment="0.01" Value="{Binding Metallic}" FormatString="0.00" />
                    </Grid>

                    <Grid ColumnDefinitions="120,*">
                      <TextBlock Classes="PropertyLabel" Text="Roughness" Grid.Column="0" />
                      <NumericUpDown Grid.Column="1" Minimum="0" Maximum="1" Increment="0.01" Value="{Binding Roughness}" FormatString="0.00" />
                    </Grid>

                    <Grid ColumnDefinitions="120,*">
                      <TextBlock Classes="PropertyLabel" Text="Albedo Texture" Grid.Column="0" />
                      <TextBox Grid.Column="1" Text="{Binding AlbedoTexture}" Watermark="Drop layer albedo here..." DragDrop.AllowDrop="True" />
                    </Grid>

                  </StackPanel>
                </Expander>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Subsurface Layer -->
          <Expander Header="Subsurface Layer">
            <StackPanel Margin="10" Spacing="8">
              
              <Grid ColumnDefinitions="120,*">
                <TextBlock Classes="PropertyLabel" Text="Amount" Grid.Column="0" />
                <NumericUpDown Grid.Column="1" Minimum="0" Maximum="1" Increment="0.01" Value="{Binding Subsurface}" FormatString="0.00" />
              </Grid>

              <Grid ColumnDefinitions="120,*">
                <TextBlock Classes="PropertyLabel" Text="Color" Grid.Column="0" />
                <Grid ColumnDefinitions="*,5,*,5,*" Grid.Column="1">
                  <NumericUpDown Grid.Column="0" Minimum="0" Maximum="1" Increment="0.01" Value="{Binding SubsurfaceColorR}" FormatString="0.00" />
                  <NumericUpDown Grid.Column="2" Minimum="0" Maximum="1" Increment="0.01" Value="{Binding SubsurfaceColorG}" FormatString="0.00" />
                  <NumericUpDown Grid.Column="4" Minimum="0" Maximum="1" Increment="0.01" Value="{Binding SubsurfaceColorB}" FormatString="0.00" />
                </Grid>
              </Grid>

              <Grid ColumnDefinitions="120,*">
                <TextBlock Classes="PropertyLabel" Text="Radius" Grid.Column="0" />
                <Grid ColumnDefinitions="*,5,*,5,*" Grid.Column="1">
                  <NumericUpDown Grid.Column="0" Minimum="0.01" Maximum="10" Increment="0.1" Value="{Binding SubsurfaceRadiusR}" FormatString="0.0" />
                  <NumericUpDown Grid.Column="2" Minimum="0.01" Maximum="10" Increment="0.1" Value="{Binding SubsurfaceRadiusG}" FormatString="0.0" />
                  <NumericUpDown Grid.Column="4" Minimum="0.01" Maximum="10" Increment="0.1" Value="{Binding SubsurfaceRadiusB}" FormatString="0.0" />
                </Grid>
              </Grid>
              
            </StackPanel>
          </Expander>

          <!-- Clearcoat Layer -->
          <Expander Header="Clearcoat Layer">
            <StackPanel Margin="10" Spacing="8">
              
              <Grid ColumnDefinitions="120,*">
                <TextBlock Classes="PropertyLabel" Text="Amount" Grid.Column="0" />
                <NumericUpDown Grid.Column="1" Minimum="0" Maximum="1" Increment="0.01" Value="{Binding Clearcoat}" FormatString="0.00" />
              </Grid>

              <Grid ColumnDefinitions="120,*">
                <TextBlock Classes="PropertyLabel" Text="Roughness" Grid.Column="0" />
                <NumericUpDown Grid.Column="1" Minimum="0" Maximum="1" Increment="0.01" Value="{Binding ClearcoatRoughness}" FormatString="0.00" />
              </Grid>
              
            </StackPanel>
          </Expander>

        </StackPanel>
      </ScrollViewer>
    </Border>
  </Grid>

</Window>
