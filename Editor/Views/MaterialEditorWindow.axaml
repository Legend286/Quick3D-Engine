<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:Engine.Editor.Views"
        x:Class="Engine.Editor.Views.MaterialEditorWindow"
        Title="Material Editor" Width="1000" Height="600"
        Background="#12151c">
  <Grid ColumnDefinitions="*,300">
    <views:ViewportMetalLayerHost Name="PreviewHost" Grid.Column="0" />
    <ScrollViewer Grid.Column="1">
      <StackPanel Margin="10" Spacing="10">
        <TextBlock Text="Material Properties" FontSize="18" FontWeight="Bold" Foreground="#d1d5da" />

        <TextBlock Text="Base Color" Foreground="#aab0b6" />
        <Grid ColumnDefinitions="*,*,*">
          <Slider Grid.Column="0" Minimum="0" Maximum="1" Value="{Binding BaseColorR}" />
          <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding BaseColorG}" />
          <Slider Grid.Column="2" Minimum="0" Maximum="1" Value="{Binding BaseColorB}" />
        </Grid>

        <TextBlock Text="Metallic" Foreground="#aab0b6" />
        <Slider Minimum="0" Maximum="1" Value="{Binding Metallic}" />

        <TextBlock Text="Roughness" Foreground="#aab0b6" />
        <Slider Minimum="0" Maximum="1" Value="{Binding Roughness}" />

        <TextBlock Text="Subsurface" Foreground="#aab0b6" />
        <Slider Minimum="0" Maximum="1" Value="{Binding Subsurface}" />

        <TextBlock Text="Subsurface Color" Foreground="#aab0b6" />
        <Grid ColumnDefinitions="*,*,*">
          <Slider Grid.Column="0" Minimum="0" Maximum="1" Value="{Binding SubsurfaceColorR}" />
          <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding SubsurfaceColorG}" />
          <Slider Grid.Column="2" Minimum="0" Maximum="1" Value="{Binding SubsurfaceColorB}" />
        </Grid>
        
        <TextBlock Text="Subsurface Radius" Foreground="#aab0b6" />
        <Grid ColumnDefinitions="*,*,*">
          <Slider Grid.Column="0" Minimum="0.01" Maximum="10" Value="{Binding SubsurfaceRadiusR}" />
          <Slider Grid.Column="1" Minimum="0.01" Maximum="10" Value="{Binding SubsurfaceRadiusG}" />
          <Slider Grid.Column="2" Minimum="0.01" Maximum="10" Value="{Binding SubsurfaceRadiusB}" />
        </Grid>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
