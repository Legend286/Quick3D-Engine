<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:vm="clr-namespace:Engine.Editor.ViewModels"
             x:Class="Engine.Editor.Views.ViewportPanelView"
             x:CompileBindings="False"
             x:DataType="vm:ViewportPanelViewModel"
             Background="#101418">
    <Border BorderBrush="#3a4046" BorderThickness="1" Margin="6">
        <Image Source="{Binding Frame}"
               Stretch="UniformToFill"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Stretch" />
    </Border>
</UserControl>
