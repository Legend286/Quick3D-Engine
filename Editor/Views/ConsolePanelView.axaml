<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Engine.Editor.ViewModels"
             x:Class="Engine.Editor.Views.ConsolePanelView"
             x:DataType="vm:ConsolePanelViewModel">

  <Grid RowDefinitions="Auto,Auto,*" Background="#0a0c10">
    <!-- Toolbar: filter buttons + search + auto-scroll -->
    <Border Grid.Row="0" Background="#12151c" Padding="8,5" BorderBrush="#1e2128" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*,Auto,Auto,Auto">
        <Button Grid.Column="0" Content="ALL" Width="36" Height="24" Margin="0,0,3,0"
                FontSize="10" FontWeight="SemiBold" CornerRadius="3"
                Background="{Binding AllBg}" Foreground="{Binding AllFg}"
                Click="OnFilterAllClicked" />
        <Button Grid.Column="1" Content="ERR" Width="36" Height="24" Margin="0,0,3,0"
                FontSize="10" FontWeight="SemiBold" CornerRadius="3"
                Background="{Binding ErrorBg}" Foreground="{Binding ErrorFg}"
                Click="OnFilterErrorClicked" />
        <Button Grid.Column="2" Content="WRN" Width="36" Height="24" Margin="0,0,3,0"
                FontSize="10" FontWeight="SemiBold" CornerRadius="3"
                Background="{Binding WarnBg}" Foreground="{Binding WarnFg}"
                Click="OnFilterWarnClicked" />
        <Button Grid.Column="3" Content="INF" Width="36" Height="24" Margin="0,0,3,0"
                FontSize="10" FontWeight="SemiBold" CornerRadius="3"
                Background="{Binding InfoBg}" Foreground="{Binding InfoFg}"
                Click="OnFilterInfoClicked" />
        <Button Grid.Column="4" Content="DBG" Width="36" Height="24" Margin="0,0,3,0"
                FontSize="10" FontWeight="SemiBold" CornerRadius="3"
                Background="{Binding DebugBg}" Foreground="{Binding DebugFg}"
                Click="OnFilterDebugClicked" />
        <Button Grid.Column="5" Content="TRC" Width="36" Height="24" Margin="0,0,6,0"
                FontSize="10" FontWeight="SemiBold" CornerRadius="3"
                Background="{Binding TraceBg}" Foreground="{Binding TraceFg}"
                Click="OnFilterTraceClicked" />

        <!-- Search box -->
        <Border Grid.Column="6" Background="#1a1d26" CornerRadius="3" Padding="6,3" Margin="4,0">
          <Grid ColumnDefinitions="Auto,*">
            <TextBlock Grid.Column="0" Text="&#xe8b6;" FontFamily="avares://Engine.Editor/Assets/MaterialIcons-Regular.ttf#Material Icons"
                       FontSize="14" Foreground="#5a5f6b" VerticalAlignment="Center" Margin="0,0,6,0" />
            <TextBox Grid.Column="1" Watermark="Filter messages..." Text="{Binding SearchText}"
                     Background="Transparent" BorderThickness="0" Foreground="#d0d4dc" FontSize="12"
                     FontFamily="Menlo,Consolas,monospace" Padding="0" />
          </Grid>
        </Border>

        <!-- Auto-scroll toggle -->
        <ToggleButton Grid.Column="7" IsChecked="{Binding AutoScroll}" Width="30" Height="24" Margin="6,0,3,0"
                      Background="Transparent" BorderThickness="0" CornerRadius="3"
                      ToolTip.Tip="Auto-scroll">
          <TextBlock Text="&#xe5d8;" FontFamily="avares://Engine.Editor/Assets/MaterialIcons-Regular.ttf#Material Icons"
                     FontSize="16" Foreground="{Binding AutoScrollIconColor}" />
        </ToggleButton>

        <!-- Clear button -->
        <Button Grid.Column="8" Width="30" Height="24" Margin="3,0,0,0"
                Background="Transparent" BorderThickness="0" CornerRadius="3"
                Click="OnClearClicked" ToolTip.Tip="Clear (Ctrl+L)">
          <TextBlock Text="&#xe872;" FontFamily="avares://Engine.Editor/Assets/MaterialIcons-Regular.ttf#Material Icons"
                     FontSize="14" Foreground="#5a5f6b" />
        </Button>

        <!-- Entry count -->
        <TextBlock Grid.Column="9" Text="{Binding CountText}" Foreground="#4a4f5b" FontSize="11"
                   VerticalAlignment="Center" Margin="10,0,0,0" />
      </Grid>
    </Border>

    <!-- Column header -->
    <Border Grid.Row="1" Background="#10141a" Padding="8,4" BorderBrush="#1e2128" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="70,84,100,*" Margin="0">
        <TextBlock Grid.Column="0" Text="LEVEL"  Foreground="#4a4f5b" FontSize="10" FontWeight="Bold" LetterSpacing="0.05" Margin="2,0" />
        <TextBlock Grid.Column="1" Text="TIME"   Foreground="#4a4f5b" FontSize="10" FontWeight="Bold" LetterSpacing="0.05" Margin="4,0" />
        <TextBlock Grid.Column="2" Text="MODULE" Foreground="#4a4f5b" FontSize="10" FontWeight="Bold" LetterSpacing="0.05" Margin="4,0" />
        <TextBlock Grid.Column="3" Text="MESSAGE" Foreground="#4a4f5b" FontSize="10" FontWeight="Bold" LetterSpacing="0.05" Margin="6,0,0,0" />
      </Grid>
    </Border>

    <!-- Log entries list -->
    <ListBox Grid.Row="2" ItemsSource="{Binding FilteredEntries}"
             Background="#0a0c10" BorderThickness="0"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             x:Name="LogListBox">
      <ListBox.Styles>
        <Style Selector="ListBoxItem">
          <Setter Property="Padding" Value="0" />
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
          <Setter Property="Background" Value="#141820" />
        </Style>
      </ListBox.Styles>
      <ListBox.ItemTemplate>
        <DataTemplate DataType="vm:ConsoleEntryViewModel">
          <Border Padding="8,4" BorderBrush="#0d0f14" BorderThickness="0,0,0,1"
                  MinHeight="32">
            <Grid ColumnDefinitions="70,84,100,*" Margin="0">
              <!-- Level badge -->
              <Border Grid.Column="0" Background="{Binding LevelBg}" CornerRadius="2" Padding="4,2"
                      HorizontalAlignment="Left" VerticalAlignment="Center">
                <TextBlock Text="{Binding Level}" FontSize="10" FontWeight="Bold"
                           Foreground="{Binding LevelColor}" FontFamily="Menlo,Consolas,monospace" />
              </Border>
              <!-- Timestamp -->
              <TextBlock Grid.Column="1" Text="{Binding Timestamp}" FontSize="11"
                         Foreground="#4a4f5b" FontFamily="Menlo,Consolas,monospace"
                         VerticalAlignment="Center" Margin="4,0" />
              <!-- Module -->
              <TextBlock Grid.Column="2" Text="{Binding Module}" FontSize="11"
                         Foreground="#6b7280" FontFamily="Menlo,Consolas,monospace"
                         VerticalAlignment="Center" Margin="4,0"
                         TextTrimming="CharacterEllipsis" />
              <!-- Message + source -->
              <StackPanel Grid.Column="3" Orientation="Vertical" Margin="4,0" VerticalAlignment="Center">
                <Button Background="Transparent" BorderThickness="0" Padding="0"
                        HorizontalAlignment="Left"
                        Click="OnSourceClicked"
                        Tag="{Binding}"
                        IsVisible="{Binding HasSource}"
                        ToolTip.Tip="{Binding SourceTooltip}">
                  <TextBlock Text="{Binding Source}" FontSize="9"
                             Foreground="{Binding SourceColor}" FontFamily="Menlo,Consolas,monospace"
                             TextDecorations="Underline" Cursor="Hand" />
                </Button>
                <TextBlock Text="{Binding Message}" FontSize="11"
                           Foreground="{Binding MessageColor}" FontFamily="Menlo,Consolas,monospace"
                           TextWrapping="Wrap" Margin="0,2,0,0" />
              </StackPanel>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Grid>
</UserControl>
