<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Engine.Editor.ViewModels"
        x:Class="Engine.Editor.Views.AssetImportWindow"
        x:DataType="vm:AssetImportViewModel"
        Width="600" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        Background="#0a0c10"
        FontFamily="-apple-system,Segoe UI,Helvetica,Arial,sans-serif"
        Title="Import Asset">

    <Border BorderBrush="#2d3139" BorderThickness="1">
        <Grid RowDefinitions="Auto,*,Auto">
            
            <!-- Title Bar -->
            <Border Grid.Row="0" Background="#1c1f24" Height="40" Padding="16,0" BorderBrush="#2d3139" BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="IMPORT ASSET" Foreground="#aab0b6" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" LetterSpacing="1.2" />
                    <Button Grid.Column="1" Width="30" Height="30" Background="Transparent" BorderThickness="0" CornerRadius="4" VerticalAlignment="Center" Click="OnCloseClicked">
                        <TextBlock Text="✕" Foreground="#5a5f6b" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" />
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="24" Spacing="20">
                <StackPanel Spacing="8">
                    <TextBlock Text="Source File (.glb / .gltf)" Foreground="#d0d4dc" FontSize="12" FontWeight="SemiBold" />
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Text="{Binding SourceFile}" Background="#12151c" BorderBrush="#2d3139" Foreground="#aab0b6" Padding="10,6" CornerRadius="4,0,0,4" Watermark="Select a model to import..." IsReadOnly="True" />
                        <Button Grid.Column="1" Content="Browse..." Background="#2d3139" Foreground="#d0d4dc" Padding="16,6" CornerRadius="0,4,4,0" Click="OnBrowseSourceClicked" />
                    </Grid>
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Text="Scale Configuration" Foreground="#d0d4dc" FontSize="12" FontWeight="SemiBold" />
                    <CheckBox Content="Uniform Scale" IsChecked="{Binding UniformScale}" Foreground="#aab0b6" />
                    <Grid ColumnDefinitions="*,12,*,12,*">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="X" Foreground="#5a5f6b" FontSize="10" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding ScaleX}" Background="#12151c" BorderBrush="#2d3139" Foreground="#aab0b6" Padding="10,6" CornerRadius="4" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Y" Foreground="#5a5f6b" FontSize="10" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding ScaleY}" Background="#12151c" BorderBrush="#2d3139" Foreground="#aab0b6" Padding="10,6" CornerRadius="4" />
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Z" Foreground="#5a5f6b" FontSize="10" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding ScaleZ}" Background="#12151c" BorderBrush="#2d3139" Foreground="#aab0b6" Padding="10,6" CornerRadius="4" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
                
                <Border Background="#12151c" BorderBrush="#1e2128" BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,8,0,0">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Import Options" Foreground="#d0d4dc" FontSize="12" FontWeight="Bold" />
                        <CheckBox Content="Extract and cook materials (.mat)" IsChecked="{Binding ImportMaterials}" Foreground="#aab0b6" />
                        <CheckBox Content="Compress textures via BasisU (.ktx2)" IsChecked="{Binding ImportTextures}" Foreground="#aab0b6" />
                    </StackPanel>
                </Border>
                
                <ProgressBar IsIndeterminate="{Binding IsIndeterminate}" Value="{Binding CookProgress}" Maximum="{Binding CookProgressMax}" IsVisible="{Binding IsCooking}" Margin="0,4,0,0" Height="4" Foreground="#32cd32" Background="#1c1f24" />
            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#12151c" Padding="16" BorderBrush="#2d3139" BorderThickness="0,1,0,0">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#5a5f6b" VerticalAlignment="Center" FontSize="11" />
                    <Button Grid.Column="1" Content="Cancel" Width="90" Background="Transparent" Foreground="#aab0b6" Padding="8,6" CornerRadius="4" Margin="0,0,8,0" Click="OnCloseClicked" HorizontalContentAlignment="Center" />
                    <Button Grid.Column="2" Content="Import" Width="100" Background="#32cd32" Foreground="#0a0c10" FontWeight="Bold" Padding="8,6" CornerRadius="4" Click="OnImportClicked" HorizontalContentAlignment="Center" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
