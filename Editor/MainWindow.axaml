<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Engine.Editor.ViewModels"
        xmlns:views="using:Engine.Editor.Views"
        x:Class="Engine.Editor.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1280" Height="800"
        MinWidth="800" MinHeight="500"
        FontFamily="-apple-system,Segoe UI,Helvetica,Arial,sans-serif"
        FontSize="13"
        Background="#12151c"
        TransparencyLevelHint="None"
        Title="{Binding WindowTitle}">

  <Window.Styles>
    <!-- Ensure all Expanders in the window stretch to full width -->
    <Style Selector="Expander">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*,Auto">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto" MinWidth="200" MaxWidth="480" />
      <ColumnDefinition Width="4" />
      <ColumnDefinition Width="*" MinWidth="300" />
      <ColumnDefinition Width="4" />
      <ColumnDefinition Width="Auto" MinWidth="200" MaxWidth="480" />
    </Grid.ColumnDefinitions>

    <!-- Top menu bar -->
    <Menu Grid.Row="0" Grid.ColumnSpan="5" FontSize="13">
      <MenuItem Header="_File">
        <MenuItem Header="_New Project…" Click="OnNewProjectClicked" />
        <MenuItem Header="_Open Project…" Click="OnOpenProjectClicked" />
        <MenuItem Header="_Open Project…" Click="OnOpenProjectClicked" />
        <Separator />
        <MenuItem Header="_New Scene" Click="OnNewSceneClicked" />
        <MenuItem Header="_Open Scene…" Click="OnOpenSceneClicked" />
        <MenuItem Header="_Save Scene" Click="OnSaveSceneClicked" />
        <MenuItem Header="Save Scene _As…" Click="OnSaveSceneAsClicked" />
        <Separator />
        <MenuItem Header="_Import Asset…" Click="OnImportAssetClicked" />
        <Separator />
        <MenuItem Header="E_xit" Click="OnExitClicked" />
      </MenuItem>
      <MenuItem Header="_Edit">
        <MenuItem Header="_Undo" />
        <MenuItem Header="_Redo" />
      </MenuItem>
      <MenuItem Header="_Window">
        <MenuItem Header="_Reset Layout" />
      </MenuItem>
      <MenuItem Header="_Tools">
        <MenuItem Header="_Material Editor" />
        <MenuItem Header="_Model Viewer" />
        <MenuItem Header="_Particle Editor" />
        <MenuItem Header="_Level Editor" />
      </MenuItem>
      <MenuItem Header="_Hot Reload" Click="OnHotReloadClicked" FontWeight="Bold" Foreground="#32cd32" />
      <MenuItem Header="_Help">
        <MenuItem Header="_About" />
      </MenuItem>
    </Menu>

    <!-- Left rail: Hierarchy / Inspector -->
    <TabControl Grid.Row="1" Grid.Column="0"
                MinWidth="200" MaxWidth="480"
                Margin="4">
      <TabItem Header="Hierarchy">
        <Border Padding="8">
          <ListBox ItemsSource="{Binding HierarchyVm.Entities}" SelectedItem="{Binding HierarchyVm.SelectedEntity}">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Name}" />
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Border>
      </TabItem>
    </TabControl>

    <!-- Drag handle between left rail and viewport -->
    <GridSplitter Grid.Row="1" Grid.Column="1"
                  Width="4"
                  HorizontalAlignment="Stretch"
                  ResizeDirection="Columns"
                  ShowsPreview="False"
                  Background="#1c1f24" />

    <!-- Center: viewport on top, collapsable consoles on the bottom -->
    <Grid Grid.Row="1" Grid.Column="2" Margin="4">
      <Grid.RowDefinitions>
        <RowDefinition Height="*" MinHeight="150" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <views:ViewportPanelView Grid.Row="0" DataContext="{Binding ViewportVm}" />

      <!-- Divider & Toggle Bar -->
      <Border Grid.Row="1" Background="#1c1f24" Height="28" BorderBrush="#2d3139" BorderThickness="0,1" Margin="0,4">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Text="BOTTOM PANELS" Foreground="#aab0b6" VerticalAlignment="Center" Margin="8,0" FontSize="11" FontWeight="SemiBold" LetterSpacing="0.05" />
          <Button Grid.Column="1" Width="28" Height="24" Background="Transparent" BorderThickness="0" Padding="0" CornerRadius="3" VerticalAlignment="Center" Margin="0,0,4,0" Click="OnToggleConsoleClicked" ToolTip.Tip="Toggle Bottom Panel">
            <Button.Styles>
              <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="#2d3139" />
              </Style>
              <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="#3e4451" />
              </Style>
            </Button.Styles>
            <TextBlock x:Name="ConsoleCollapseIcon" Text="&#xe313;" FontFamily="avares://Engine.Editor/Assets/MaterialIcons-Regular.ttf#Material Icons" FontSize="18" Foreground="#aab0b6" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Button>
        </Grid>
      </Border>

      <TabControl x:Name="ConsolesTabControl" Grid.Row="2"
                  MinHeight="80" MaxHeight="800"
                  Height="300" IsVisible="True">
        <TabItem Header="Content Browser">
          <views:ContentBrowserView DataContext="{Binding ContentBrowserVm}" />
        </TabItem>
        <TabItem Header="Console">
          <views:ConsolePanelView DataContext="{Binding ConsoleVm}" />
        </TabItem>
        <TabItem Header="Profiler">
          <Border Padding="8">
            <TextBlock Text="(empty - Phase 4)" FontSize="13" />
          </Border>
        </TabItem>
        <TabItem Header="Localization">
          <Border Padding="8">
            <TextBlock Text="(empty - Phase 4)" FontSize="13" />
          </Border>
        </TabItem>
      </TabControl>
    </Grid>

    <!-- Drag handle between viewport and right rail -->
    <GridSplitter Grid.Row="1" Grid.Column="3"
                  Width="4"
                  HorizontalAlignment="Stretch"
                  ResizeDirection="Columns"
                  ShowsPreview="False"
                  Background="#1c1f24" />

    <!-- Right rail: Inspector -->
    <Border Grid.Row="1" Grid.Column="4" MinWidth="200" MaxWidth="480" Margin="4" Background="#1c1f24" BorderBrush="#2d3139" BorderThickness="1" CornerRadius="4">
      <Grid RowDefinitions="Auto,*">
        <Border Background="#2d3139" Padding="10,6" CornerRadius="4,4,0,0">
          <TextBlock Text="Inspector" FontWeight="Bold" Foreground="#e0e0e0" />
        </Border>
        <Border Grid.Row="1" Padding="8" DataContext="{Binding InspectorVm}">
          <ScrollViewer>
            <StackPanel Spacing="10">
              <TextBlock Text="{Binding EntityName}" FontWeight="Bold" FontSize="16" />
              
              <Border IsVisible="{Binding !HasSelection}" Padding="10" Background="#2d3139" CornerRadius="4">
                <TextBlock Text="Select an entity to view its properties." FontStyle="Italic" Foreground="#aab0b6" />
              </Border>
              
              <!-- Transform Component -->
              <Expander Header="Transform" IsVisible="{Binding HasTransform}" IsExpanded="True">
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" Margin="0,10,0,0">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Position" VerticalAlignment="Center" Margin="0,0,10,0"/>
                  <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="*,*,*" Margin="0,0,0,5">
                    <Grid Grid.Column="0" ColumnDefinitions="Auto,*" Margin="0,0,4,0">
                      <TextBlock Grid.Column="0" Text="X" VerticalAlignment="Center" Foreground="#ff6b6b" Margin="0,0,4,0"/>
                      <NumericUpDown Grid.Column="1" Value="{Binding PosX}" Increment="0.1" FormatString="0.00" HorizontalAlignment="Stretch" />
                    </Grid>
                    <Grid Grid.Column="1" ColumnDefinitions="Auto,*" Margin="0,0,4,0">
                      <TextBlock Grid.Column="0" Text="Y" VerticalAlignment="Center" Foreground="#51cf66" Margin="0,0,4,0"/>
                      <NumericUpDown Grid.Column="1" Value="{Binding PosY}" Increment="0.1" FormatString="0.00" HorizontalAlignment="Stretch" />
                    </Grid>
                    <Grid Grid.Column="2" ColumnDefinitions="Auto,*">
                      <TextBlock Grid.Column="0" Text="Z" VerticalAlignment="Center" Foreground="#339af0" Margin="0,0,4,0"/>
                      <NumericUpDown Grid.Column="1" Value="{Binding PosZ}" Increment="0.1" FormatString="0.00" HorizontalAlignment="Stretch" />
                    </Grid>
                  </Grid>

                  <TextBlock Grid.Row="1" Grid.Column="0" Text="Rotation" VerticalAlignment="Center" Margin="0,0,10,0"/>
                  <Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="*,*,*" Margin="0,0,0,5">
                    <Grid Grid.Column="0" ColumnDefinitions="Auto,*" Margin="0,0,4,0">
                      <TextBlock Grid.Column="0" Text="X" VerticalAlignment="Center" Foreground="#ff6b6b" Margin="0,0,4,0"/>
                      <NumericUpDown Grid.Column="1" Value="{Binding RotX}" Increment="1" FormatString="0.0" HorizontalAlignment="Stretch" />
                    </Grid>
                    <Grid Grid.Column="1" ColumnDefinitions="Auto,*" Margin="0,0,4,0">
                      <TextBlock Grid.Column="0" Text="Y" VerticalAlignment="Center" Foreground="#51cf66" Margin="0,0,4,0"/>
                      <NumericUpDown Grid.Column="1" Value="{Binding RotY}" Increment="1" FormatString="0.0" HorizontalAlignment="Stretch" />
                    </Grid>
                    <Grid Grid.Column="2" ColumnDefinitions="Auto,*">
                      <TextBlock Grid.Column="0" Text="Z" VerticalAlignment="Center" Foreground="#339af0" Margin="0,0,4,0"/>
                      <NumericUpDown Grid.Column="1" Value="{Binding RotZ}" Increment="1" FormatString="0.0" HorizontalAlignment="Stretch" />
                    </Grid>
                  </Grid>

                  <TextBlock Grid.Row="2" Grid.Column="0" Text="Scale" VerticalAlignment="Center" Margin="0,0,10,0"/>
                  <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*,*,*" Margin="0,0,0,5">
                    <Grid Grid.Column="0" ColumnDefinitions="Auto,*" Margin="0,0,4,0">
                      <TextBlock Grid.Column="0" Text="X" VerticalAlignment="Center" Foreground="#ff6b6b" Margin="0,0,4,0"/>
                      <NumericUpDown Grid.Column="1" Value="{Binding ScaleX}" Increment="0.1" FormatString="0.00" HorizontalAlignment="Stretch" />
                    </Grid>
                    <Grid Grid.Column="1" ColumnDefinitions="Auto,*" Margin="0,0,4,0">
                      <TextBlock Grid.Column="0" Text="Y" VerticalAlignment="Center" Foreground="#51cf66" Margin="0,0,4,0"/>
                      <NumericUpDown Grid.Column="1" Value="{Binding ScaleY}" Increment="0.1" FormatString="0.00" HorizontalAlignment="Stretch" />
                    </Grid>
                    <Grid Grid.Column="2" ColumnDefinitions="Auto,*">
                      <TextBlock Grid.Column="0" Text="Z" VerticalAlignment="Center" Foreground="#339af0" Margin="0,0,4,0"/>
                      <NumericUpDown Grid.Column="1" Value="{Binding ScaleZ}" Increment="0.1" FormatString="0.00" HorizontalAlignment="Stretch" />
                    </Grid>
                  </Grid>
                </Grid>
              </Expander>

              <!-- Model Component -->
              <Expander Header="Model Component" IsVisible="{Binding HasModel}" IsExpanded="True">
                <Grid ColumnDefinitions="Auto,*">
                  <TextBlock Grid.Column="0" Text="Model ID:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                  <TextBox Grid.Column="1" Text="{Binding ModelId}" HorizontalAlignment="Stretch" IsReadOnly="True" />
                </Grid>
              </Expander>

              <!-- Camera Component -->
              <Expander Header="Camera" IsVisible="{Binding HasCamera}" IsExpanded="True">
                <Grid ColumnDefinitions="Auto,*">
                  <TextBlock Grid.Column="0" Text="FOV (Y):" VerticalAlignment="Center" Margin="0,0,10,0"/>
                  <TextBox Grid.Column="1" Text="{Binding CameraFov, StringFormat=\{0:F2\}}" HorizontalAlignment="Stretch" IsReadOnly="True" />
                </Grid>
              </Expander>

            </StackPanel>
          </ScrollViewer>
        </Border>
      </Grid>
    </Border>

    <!-- Status bar -->
    <Border Grid.Row="2" Grid.ColumnSpan="5"
            Background="#1c1f24" Padding="8,4">
      <TextBlock Text="{Binding StatusText}"
                 Foreground="#aab0b6" FontSize="12" />
    </Border>
  </Grid>
</Window>
