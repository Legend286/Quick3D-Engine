<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Engine.Editor.ViewModels"
        xmlns:views="using:Engine.Editor.Views"
        x:Class="Engine.Editor.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1280" Height="800"
        MinWidth="800" MinHeight="500"
        FontFamily="-apple-system,Segoe UI,Helvetica,Arial,sans-serif"
        FontSize="13"
        Title="End Engine — Editor">

  <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="Auto,4,*,4,Auto">

    <!-- Top menu bar -->
    <Menu Grid.Row="0" Grid.ColumnSpan="5" FontSize="13">
      <MenuItem Header="_File">
        <MenuItem Header="_Open Project…" />
        <MenuItem Header="_Save" />
        <Separator />
        <MenuItem Header="E_xit" Click="OnExitClicked" />
      </MenuItem>
      <MenuItem Header="_Edit">
        <MenuItem Header="_Undo" />
        <MenuItem Header="_Redo" />
      </MenuItem>
      <MenuItem Header="_Window">
        <MenuItem Header="_Reset Layout" />
      </MenuItem>
      <MenuItem Header="_Tools">
        <MenuItem Header="_Material Editor" />
        <MenuItem Header="_Model Viewer" />
        <MenuItem Header="_Particle Editor" />
        <MenuItem Header="_Level Editor" />
      </MenuItem>
      <MenuItem Header="_Help">
        <MenuItem Header="_About" />
      </MenuItem>
    </Menu>

    <!-- Left rail: Hierarchy / Inspector -->
    <TabControl Grid.Row="1" Grid.Column="0"
                MinWidth="200" MaxWidth="480"
                Margin="4">
      <TabItem Header="Hierarchy">
        <Border Padding="8">
          <TextBlock Text="(empty - Phase 1)" FontSize="13" />
        </Border>
      </TabItem>
      <TabItem Header="Inspector">
        <Border Padding="8">
          <TextBlock Text="(empty - Phase 1)" FontSize="13" />
        </Border>
      </TabItem>
    </TabControl>

    <!-- Drag handle between left rail and viewport -->
    <GridSplitter Grid.Row="1" Grid.Column="1"
                  Width="4"
                  HorizontalAlignment="Stretch"
                  ResizeDirection="Columns"
                  ShowsPreview="True"
                  Background="#1c1f24" />

    <!-- Center: viewport on top, dockable consoles on the bottom, drag handle
         between them. Shrinking/expanding the consoles expands the viewport. -->
    <Grid Grid.Row="1" Grid.Column="2" Margin="4"
          RowDefinitions="*,4,Auto">
      <views:ViewportPanelView Grid.Row="0" DataContext="{Binding ViewportVm}" />

      <GridSplitter Grid.Row="1"
                    Height="4"
                    HorizontalAlignment="Stretch"
                    ResizeDirection="Rows"
                    ShowsPreview="True"
                    Background="#1c1f24" />

      <TabControl Grid.Row="2"
                  MinHeight="80" MaxHeight="480"
                  Height="200">
        <TabItem Header="Console">
          <views:ConsolePanelView DataContext="{Binding ConsoleVm}" />
        </TabItem>
        <TabItem Header="Profiler">
          <Border Padding="8">
            <TextBlock Text="(empty - Phase 4)" FontSize="13" />
          </Border>
        </TabItem>
        <TabItem Header="Localization">
          <Border Padding="8">
            <TextBlock Text="(empty - Phase 4)" FontSize="13" />
          </Border>
        </TabItem>
      </TabControl>
    </Grid>

    <!-- Drag handle between viewport and right rail -->
    <GridSplitter Grid.Row="1" Grid.Column="3"
                  Width="4"
                  HorizontalAlignment="Stretch"
                  ResizeDirection="Columns"
                  ShowsPreview="True"
                  Background="#1c1f24" />

    <!-- Right rail: Assets / Source Control -->
    <TabControl Grid.Row="1" Grid.Column="4"
                MinWidth="200" MaxWidth="480"
                Margin="4">
      <TabItem Header="Assets">
        <Border Padding="8">
          <TextBlock Text="(empty - Phase 2)" FontSize="13" />
        </Border>
      </TabItem>
      <TabItem Header="Source Control">
        <Border Padding="8">
          <TextBlock Text="(empty - Phase 5)" FontSize="13" />
        </Border>
      </TabItem>
    </TabControl>

    <!-- Status bar -->
    <Border Grid.Row="2" Grid.ColumnSpan="5"
            Background="#1c1f24" Padding="8,4">
      <TextBlock Text="{Binding StatusText}"
                 Foreground="#aab0b6" FontSize="12" />
    </Border>
  </Grid>
</Window>
