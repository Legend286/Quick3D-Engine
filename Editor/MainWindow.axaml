<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Engine.Editor.ViewModels"
        xmlns:views="using:Engine.Editor.Views"
        x:Class="Engine.Editor.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1280" Height="800"
        MinWidth="800" MinHeight="500"
        FontFamily="-apple-system,Segoe UI,Helvetica,Arial,sans-serif"
        FontSize="13"
        Title="End Engine — Editor">

  <Grid RowDefinitions="Auto,*,Auto">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto" MinWidth="200" MaxWidth="480" />
      <ColumnDefinition Width="4" />
      <ColumnDefinition Width="*" MinWidth="300" />
      <ColumnDefinition Width="4" />
      <ColumnDefinition Width="Auto" MinWidth="200" MaxWidth="480" />
    </Grid.ColumnDefinitions>

    <!-- Top menu bar -->
    <Menu Grid.Row="0" Grid.ColumnSpan="5" FontSize="13">
      <MenuItem Header="_File">
        <MenuItem Header="_New Project…" Click="OnNewProjectClicked" />
        <MenuItem Header="_Open Project…" Click="OnOpenProjectClicked" />
        <MenuItem Header="_Save" />
        <Separator />
        <MenuItem Header="_Import Asset…" Click="OnImportAssetClicked" />
        <Separator />
        <MenuItem Header="E_xit" Click="OnExitClicked" />
      </MenuItem>
      <MenuItem Header="_Edit">
        <MenuItem Header="_Undo" />
        <MenuItem Header="_Redo" />
      </MenuItem>
      <MenuItem Header="_Window">
        <MenuItem Header="_Reset Layout" />
      </MenuItem>
      <MenuItem Header="_Tools">
        <MenuItem Header="_Material Editor" />
        <MenuItem Header="_Model Viewer" />
        <MenuItem Header="_Particle Editor" />
        <MenuItem Header="_Level Editor" />
      </MenuItem>
      <MenuItem Header="_Hot Reload" Click="OnHotReloadClicked" FontWeight="Bold" Foreground="#32cd32" />
      <MenuItem Header="_Help">
        <MenuItem Header="_About" />
      </MenuItem>
    </Menu>

    <!-- Left rail: Hierarchy / Inspector -->
    <TabControl Grid.Row="1" Grid.Column="0"
                MinWidth="200" MaxWidth="480"
                Margin="4">
      <TabItem Header="Hierarchy">
        <Border Padding="8">
          <TextBlock Text="(empty - Phase 1)" FontSize="13" />
        </Border>
      </TabItem>
      <TabItem Header="Inspector">
        <Border Padding="8">
          <TextBlock Text="(empty - Phase 1)" FontSize="13" />
        </Border>
      </TabItem>
    </TabControl>

    <!-- Drag handle between left rail and viewport -->
    <GridSplitter Grid.Row="1" Grid.Column="1"
                  Width="4"
                  HorizontalAlignment="Stretch"
                  ResizeDirection="Columns"
                  ShowsPreview="False"
                  Background="#1c1f24" />

    <!-- Center: viewport on top, collapsable consoles on the bottom -->
    <Grid Grid.Row="1" Grid.Column="2" Margin="4">
      <Grid.RowDefinitions>
        <RowDefinition Height="*" MinHeight="150" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <views:ViewportPanelView Grid.Row="0" DataContext="{Binding ViewportVm}" />

      <!-- Divider & Toggle Bar -->
      <Border Grid.Row="1" Background="#1c1f24" Height="28" BorderBrush="#2d3139" BorderThickness="0,1" Margin="0,4">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Text="CONSOLE &amp; DIAGNOSTICS" Foreground="#aab0b6" VerticalAlignment="Center" Margin="8,0" FontSize="11" FontWeight="SemiBold" LetterSpacing="0.05" />
          <Button Grid.Column="1" Width="28" Height="24" Background="Transparent" BorderThickness="0" Padding="0" CornerRadius="3" VerticalAlignment="Center" Margin="0,0,4,0" Click="OnToggleConsoleClicked" ToolTip.Tip="Toggle Console">
            <Button.Styles>
              <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="#2d3139" />
              </Style>
              <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="#3e4451" />
              </Style>
            </Button.Styles>
            <TextBlock x:Name="ConsoleCollapseIcon" Text="&#xe313;" FontFamily="avares://Engine.Editor/Assets/MaterialIcons-Regular.ttf#Material Icons" FontSize="18" Foreground="#aab0b6" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Button>
        </Grid>
      </Border>

      <TabControl x:Name="ConsolesTabControl" Grid.Row="2"
                  MinHeight="80" MaxHeight="800"
                  Height="450" IsVisible="True">
        <TabItem Header="Console">
          <views:ConsolePanelView DataContext="{Binding ConsoleVm}" />
        </TabItem>
        <TabItem Header="Profiler">
          <Border Padding="8">
            <TextBlock Text="(empty - Phase 4)" FontSize="13" />
          </Border>
        </TabItem>
        <TabItem Header="Localization">
          <Border Padding="8">
            <TextBlock Text="(empty - Phase 4)" FontSize="13" />
          </Border>
        </TabItem>
      </TabControl>
    </Grid>

    <!-- Drag handle between viewport and right rail -->
    <GridSplitter Grid.Row="1" Grid.Column="3"
                  Width="4"
                  HorizontalAlignment="Stretch"
                  ResizeDirection="Columns"
                  ShowsPreview="False"
                  Background="#1c1f24" />

    <!-- Right rail: Assets / Source Control -->
    <TabControl Grid.Row="1" Grid.Column="4"
                MinWidth="200" MaxWidth="480"
                Margin="4">
      <TabItem Header="Assets">
        <Border Padding="8">
          <TextBlock Text="(empty - Phase 2)" FontSize="13" />
        </Border>
      </TabItem>
      <TabItem Header="Source Control">
        <Border Padding="8">
          <TextBlock Text="(empty - Phase 5)" FontSize="13" />
        </Border>
      </TabItem>
    </TabControl>

    <!-- Status bar -->
    <Border Grid.Row="2" Grid.ColumnSpan="5"
            Background="#1c1f24" Padding="8,4">
      <TextBlock Text="{Binding StatusText}"
                 Foreground="#aab0b6" FontSize="12" />
    </Border>
  </Grid>
</Window>
